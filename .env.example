# ==============================================================================
# Mahathi Tailor Shop - Environment Configuration Template
# ==============================================================================
# 
# This file serves as a template for local environment variables.
# Copy this file to `.env` or set these keys in your hosting provider's dashboard.
#
# NOTE ON DEPLOYMENT ARCHITECTURE:
# The application uses a dynamic client-side Firebase loader. If the keys below are 
# provided, the application will initialize cloud Firebase Auth and Firestore.
# Otherwise, it automatically falls back to full simulated LocalStorage BoutiqueDB.

# Firebase Cloud Integration Credentials
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_auth_domain_here
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
FIREBASE_APP_ID=your_app_id_here
